# ── Environment files — NEVER commit these ──────────────────
.env
backend/.env
frontend/.env
frontend/.env.local
*.env

# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Next.js build output ─────────────────────────────────────
frontend/.next/
frontend/out/
.next/

# ── Uploaded files ───────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor files ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Testing ──────────────────────────────────────────────────
coverage/

# ── Claude Code ──────────────────────────────────────────────
.claude/
